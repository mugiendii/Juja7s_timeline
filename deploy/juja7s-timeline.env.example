# Copy to /etc/juja7s-timeline.env on the VPS (chmod 600, owned by root) and fill in.
# Loopback only — nginx is the only thing that should be able to reach this app.
HOST=127.0.0.1
PORT=3333

SEVENS_API_URL=https://sevens.mugiendii.com

TOURNAMENT_NAME=Juja 7s
HOST_NAME=JKUAT Cougars
TOURNAMENT_VENUE=JKUAT Main Campus, Juja

THEME_PRIMARY=#C8102E
THEME_DARK=#111111
THEME_LIGHT=#ffffff
THEME_ACCENT=#8BC34A
THEME_LOGO_URL=/img/logo.jpg

# 16 teams / 4 pools of 4 — top 2 per pool advance to the Cup.
POOL_QUALIFY_TOP_N=2
